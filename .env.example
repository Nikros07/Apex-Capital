# ── OpenRouter API Keys (round-robin, 1 per agent) ──────────────────────────
OPENROUTER_KEY_1=sk-or-v1-...
OPENROUTER_KEY_2=sk-or-v1-...
OPENROUTER_KEY_3=sk-or-v1-...
OPENROUTER_KEY_4=sk-or-v1-...
OPENROUTER_KEY_5=sk-or-v1-...

# ── Tavily Search ────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Reddit API (create app at reddit.com/prefs/apps) ─────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ApexCapital/1.0

# ── Portfolio ────────────────────────────────────────────────────────────────
ACCOUNT_SIZE=10000
WATCHLIST=AAPL,TSLA,NVDA,MSFT,SPY

# ── Scheduler ────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=15

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
DB_PATH=apex.db
