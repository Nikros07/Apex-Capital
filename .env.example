# ── OpenRouter API Keys (round-robin, 1 key per agent) ───────────────────────
# Get free keys at https://openrouter.ai → Keys
# All 5 are used for parallel agents — you can duplicate the same key if needed
OPENROUTER_KEY_1=sk-or-v1-...
OPENROUTER_KEY_2=sk-or-v1-...
OPENROUTER_KEY_3=sk-or-v1-...
OPENROUTER_KEY_4=sk-or-v1-...
OPENROUTER_KEY_5=sk-or-v1-...

# ── Tavily Web Search ─────────────────────────────────────────────────────────
# Get key at https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ── Reddit API ────────────────────────────────────────────────────────────────
# Create a "script" app at https://reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ApexCapital/1.0

# ── Portfolio ─────────────────────────────────────────────────────────────────
ACCOUNT_SIZE=10000
WATCHLIST=AAPL,TSLA,NVDA,MSFT,SPY
SCAN_INTERVAL_MINUTES=15

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL: leave blank — defaults to ./apex.db
# RAILWAY: set to /data/apex.db AND add a Volume mounted at /data in Railway dashboard
#          (Railway > Project > Volumes > Add Volume > mount path: /data)
# DB_PATH=/data/apex.db

# ── Server (Railway sets PORT automatically — do not set manually on Railway) ─
PORT=8000
